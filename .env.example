DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/vehicle_db
JWT_SECRET_KEY=change-me

# Optional outbound services (leave blank for local dev; user validation & proxies are skipped).
USER_MS_BASE_URL=
USER_MS_VALIDATE_PATH=/api/u1/users/internal/validate
USER_MS_INTERNAL_API_KEY=

# Order MS calls POST /api/v1/vehicles/internal/details with this header when set.
INTERNAL_API_KEY=

MEDIA_MS_BASE_URL=
MEDIA_MS_UPLOAD_PATH=/api/v1/media/upload

# Tracking is stored in this service (vehicle_positions). Optional legacy fallback if no local rows:
TRACKING_MS_BASE_URL=
TRACKING_MS_VEHICLE_PATH=/api/v1/vehicles/{vehicle_id}/tracking

TICKET_MS_BASE_URL=
TICKET_MS_CREATE_PATH=/api/v1/tickets/create
TICKET_MS_APPROVE_PATH=/api/v1/tickets/approve

ANALYTICS_MS_BASE_URL=
ANALYTICS_MS_VEHICLE_SUMMARY_PATH=/api/v1/analytics/vehicle-summary

PUBLIC_APP_URL=http://localhost:8000
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_MB=10
